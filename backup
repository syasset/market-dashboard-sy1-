@st.cache_data(ttl=600)
def load_all_data():
    # 1. 티커-이름 매핑 정의 (중복 티커 제거를 위해 구조 변경)
    # ^IRX는 미국 3개월물 국채 수익률이므로 정확한 명칭으로 하나만 사용 권장
